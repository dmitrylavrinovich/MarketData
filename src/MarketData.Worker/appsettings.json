{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Exchanges": [
    { "Name": "ExchangeA", "Url": "ws://localhost:5095/ws/exchange-a", "Parser": "JsonSnake" },
    { "Name": "ExchangeB", "Url": "ws://localhost:5095/ws/exchange-b", "Parser": "JsonNested" },
    { "Name": "ExchangeC", "Url": "ws://localhost:5095/ws/exchange-c", "Parser": "Csv" }
  ],
  "Pipeline": { "ChannelCapacity": 50000, "BatchSize": 500, "BatchTimeoutMs": 200 },
  "Dedup": { "WindowTtlSeconds": 300, "MaxEntries": 200000 },
  "Reconnect": { "BaseDelayMs": 500, "MaxDelayMs": 30000, "IdleTimeoutSeconds": 30 },
  "Metrics": { "ReportIntervalSeconds": 10 },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Database=marketdata;Username=postgres;Password=postgres"
  }
}
